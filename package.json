{
  "name": "coverfire",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names cover,server \"pnpm dev:cover\" \"pnpm dev:server\"",
    "dev:cover": "vite",
    "dev:server": "PUPPETEER_CACHE_DIR=.cache/puppeteer tsx watch server/index.ts",
    "start": "pnpm start:server",
    "start:cover": "vite preview --host localhost --port 4173",
    "start:server": "PUPPETEER_CACHE_DIR=.cache/puppeteer tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:render": "PUPPETEER_CACHE_DIR=.cache/puppeteer pnpm exec puppeteer browsers install chrome && pnpm build",
    "lint": "eslint .",
    "preview": "pnpm start:cover"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.18.0",
    "puppeteer": "^25.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.5"
  }
}
