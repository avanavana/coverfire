COVERFIRE_API_KEY=replace-me
# Optional Basic Auth protection for /admin and /api/admin*.
ADMIN_BASIC_AUTH_ENABLED=
ADMIN_BASIC_AUTH_USERNAME=
ADMIN_BASIC_AUTH_PASSWORD=
ADMIN_BASIC_AUTH_REALM="Coverfire Admin"
PORT=3000
# Optional for local testing against an already-running Vite server.
# Example: http://127.0.0.1:5173
COVERFIRE_RENDER_ORIGIN=
# Optional if Puppeteer should use a specific local Chrome/Chromium binary.
PUPPETEER_EXECUTABLE_PATH=
# Optional explicit Puppeteer cache directory.
PUPPETEER_CACHE_DIR=
# Optional local JSON admin store path when Upstash Redis is not configured.
COVERFIRE_LOCAL_STORE_PATH=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
