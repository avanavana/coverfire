COVERFIRE_API_KEY=replace-me
PORT=3000
# Optional for local testing against an already-running Vite server.
# Example: http://127.0.0.1:5173
COVERFIRE_RENDER_ORIGIN=
# Optional if Puppeteer should use a specific local Chrome/Chromium binary.
PUPPETEER_EXECUTABLE_PATH=
# Optional explicit Puppeteer cache directory.
PUPPETEER_CACHE_DIR=
